
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Book {
  bookId String @id @default(uuid()) @db.Uuid
  title String
  author String
  description String
  price Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

